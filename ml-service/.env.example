# ── TaskFlow AI ML Microservice ──────────────────────────────
# Copy this file to .env and fill in your values

# MongoDB connection string (same as Node.js backend)
MONGODB_URI=mongodb://localhost:27017/taskflownew

# Server settings
PORT=8000
HOST=0.0.0.0

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5000,http://localhost:3000,http://localhost:5173

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Training thresholds (minimum samples needed to train each model)
MIN_EFFORT_SAMPLES=30
MIN_DELAY_SAMPLES=20
MIN_PRIORITY_SAMPLES=30
MIN_ASSIGNEE_SAMPLES=20
