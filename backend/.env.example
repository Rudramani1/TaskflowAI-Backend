# ═══════════════════════════════════════════════════════════════
# TaskFlow AI Backend — Environment Variables
# Copy this to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB ─────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=Cluster0

# ── JWT Secret (use a random 64-char string) ───────────────
JWT_SECRET=

# ── Frontend URL (for CORS & invite emails) ────────────────
CLIENT_URL=https://your-frontend.vercel.app

# ── SMTP Email (optional — falls back to console logging) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="TaskFlow AI" <noreply@taskflow.ai>
